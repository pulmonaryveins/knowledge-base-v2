# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.
#
# NOTE: SUPABASE_URL and SUPABASE_ANON_KEY are intentionally in
# supabase.service.ts (they are public values by design).
# Only the service role key belongs here.

# Supabase Edge Function — server-side only, never sent to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Default admin account — create this user via Supabase dashboard, then run:
#   UPDATE public.profiles SET role = 'admin' WHERE email = '...';
DEFAULT_ADMIN_EMAIL=admin@ncompasstv.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
